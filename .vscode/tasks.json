{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve site (localhost:8000)",
      "type": "shell",
      "command": "python",
      "args": ["-m", "http.server", "8000"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "http-server",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Static file server for the site. Ctrl+Shift+B to start."
    }
  ]
}
